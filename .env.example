# Copy to .env and fill in the values you actually want to use on the target machine.

# OpenClaw install target
OPENCLAW_PROFILE=chibaclaw
OPENCLAW_WORKSPACE_DIR=.
OPENCLAW_AGENT_ID=chibaclaw
OPENCLAW_AGENT_NAME=ChibaClaw
OPENCLAW_AGENT_EMOJI=
OPENCLAW_AGENT_AVATAR=
OPENCLAW_AGENT_MODEL=

# Run this profile on a dedicated gateway port so it can coexist with other OpenClaw profiles.
OPENCLAW_GATEWAY_PORT=19789
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_GATEWAY_TOKEN=<set-a-random-token>
OPENCLAW_GATEWAY_RUNTIME=node
OPENCLAW_INSTALL_GATEWAY_SERVICE=1
OPENCLAW_START_GATEWAY_SERVICE=1
OPENCLAW_DISCORD_INBOUND_WORKER_TIMEOUT_MS=600000

# Docker Compose bootstrap for running the gateway in a container.
# scripts/openclaw-docker.sh writes a derived .openclaw-docker.env and overrides
# the host service install/start flags automatically.
OPENCLAW_DOCKER_IMAGE=chibaclaw-openclaw:latest
OPENCLAW_DOCKER_BASE_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_DOCKER_UV_IMAGE=ghcr.io/astral-sh/uv:0.8.17
OPENCLAW_DOCKER_STATE_DIR=$HOME/.openclaw
OPENCLAW_DOCKER_PROJECT_NAME=chibaclaw
# Usually auto-detected from the invoking user. Override only if the repo or
# state dir on the host is owned by a different UID/GID.
OPENCLAW_DOCKER_UID=
OPENCLAW_DOCKER_GID=
OPENCLAW_DOCKER_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_EXPOSE_HOST=127.0.0.1
# Keep this at 1 for gateway-only installs. Set to 0 only if the container also
# has access to any sibling repos and service config your skills expect.
OPENCLAW_SKIP_SKILL_SETUP=1

# Discord interaction surface
OPENCLAW_ENABLE_DISCORD=1
DISCORD_BOT_TOKEN=<discord-bot-token>
DISCORD_GROUP_POLICY=allowlist
DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_DM_POLICY=pairing
DISCORD_ALLOW_FROM=

# Chiba controller
CHIBA_API_URL=
CHIBA_CONTROLLER_HOST=
CHIBA_CONTROLLER_REPO=../chiba-controller

# Eden
EDEN_API_URL=
EDEN_API_KEY=
EDEN_POLL_INTERVAL_SECONDS=2
EDEN_TOOL_TIMEOUT_SECONDS=300

# Lorebook / Mars lore
LOREBOOK_URL=https://docs.google.com/spreadsheets/d/<sheet-id>/edit
MARS_LORE_OUTPUT_DIR=outputs/mars-lore
