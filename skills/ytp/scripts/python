#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PYTHON_BIN="$SKILL_DIR/.venv/bin/python"

if [[ -n "${CHIBA_PYTHON_BIN:-}" ]]; then
  exec "$CHIBA_PYTHON_BIN" "$@"
fi

if [[ ! -x "$PYTHON_BIN" ]]; then
  "$SKILL_DIR/setup.sh" >/dev/null
fi

exec "$PYTHON_BIN" "$@"
