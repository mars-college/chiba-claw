#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PYTHON_BIN="$SKILL_DIR/.venv/bin/python"

if [[ -n "${CHIBA_FFMPEG_BIN:-}" ]]; then
  exec "$CHIBA_FFMPEG_BIN" "$@"
fi

if [[ ! -x "$PYTHON_BIN" ]]; then
  "$SKILL_DIR/setup.sh" >/dev/null
fi

if ! FFMPEG_BIN="$("$PYTHON_BIN" "$SCRIPT_DIR/ffmpeg_path.py" 2>/dev/null)"; then
  "$SKILL_DIR/setup.sh" >/dev/null
  FFMPEG_BIN="$("$PYTHON_BIN" "$SCRIPT_DIR/ffmpeg_path.py")"
fi

exec "$FFMPEG_BIN" "$@"
